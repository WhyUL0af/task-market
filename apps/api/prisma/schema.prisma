generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum TaskStatus {
  DRAFT
  OPEN
  APPLIED
  IN_PROGRESS
  REVIEW
  DONE
  CANCELLED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  WAITLIST
  REJECTED
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TaskDifficulty {
  EASY
  MEDIUM
  HARD
}

enum ProfileTagType {
  SKILL
}

model User {
  id                   String                  @id @default(cuid())
  email                String                  @unique
  name                 String
  bio                  String?
  notificationSettings Json                    @default("{\"email\":true,\"taskUpdates\":true,\"reviewResults\":true}")
  passwordHash         String
  role                 Role                    @default(EMPLOYEE)
  xp                   Int                     @default(0)
  level                Int                     @default(1)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  createdTasks         Task[]                  @relation("CreatedTasks")
  applications         TaskApplication[]
  submissions          TaskSubmission[]
  comments             Comment[]
  badges               UserBadge[]
  profileTags          UserProfileTag[]
  expTransactions      ExpTransaction[]
  challengeProgress    UserChallengeProgress[]
}

model Task {
  id              String            @id @default(cuid())
  title           String
  description     String
  reward          Int?
  dueAt           DateTime?
  difficulty      TaskDifficulty    @default(MEDIUM)
  xpReward        Int               @default(100)
  status          TaskStatus        @default(DRAFT)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  creatorId       String
  creator         User              @relation("CreatedTasks", fields: [creatorId], references: [id])
  requirements    TaskRequirement[]
  applications    TaskApplication[]
  submissions     TaskSubmission[]
  comments        Comment[]
  expTransactions ExpTransaction[]
}

model Badge {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String
  icon        String
  createdAt   DateTime    @default(now())
  users       UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  earnedAt DateTime @default(now())
  active   Boolean  @default(false)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model ExpTransaction {
  id        String   @id @default(cuid())
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([taskId])
}

model WeeklyChallenge {
  id          String                  @id @default(cuid())
  code        String                  @unique
  title       String
  description String
  metric      String
  target      Int
  expReward   Int                     @default(0)
  active      Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  progress    UserChallengeProgress[]
}

model UserChallengeProgress {
  id          String          @id @default(cuid())
  weekStart   DateTime
  value       Int             @default(0)
  completed   Boolean         @default(false)
  completedAt DateTime?
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeId String
  challenge   WeeklyChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId, weekStart])
}

model ProfileTag {
  id                    String                 @id @default(cuid())
  name                  String
  type                  ProfileTagType
  createdAt             DateTime               @default(now())
  users                 UserProfileTag[]
  taskRequirementSkills TaskRequirementSkill[]

  @@unique([type, name])
}

model TaskRequirement {
  id            String                 @id @default(cuid())
  name          String?
  headcount     Int                    @default(1)
  budgetPercent Int                    @default(0)
  xpPercent     Int                    @default(0)
  createdAt     DateTime               @default(now())
  taskId        String
  task          Task                   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  skills        TaskRequirementSkill[]
  applications  TaskApplication[]

  @@index([taskId])
}

model TaskRequirementSkill {
  id            String          @id @default(cuid())
  requirementId String
  skillTagId    String
  createdAt     DateTime        @default(now())
  requirement   TaskRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  skillTag      ProfileTag      @relation(fields: [skillTagId], references: [id], onDelete: Cascade)

  @@unique([requirementId, skillTagId])
  @@index([skillTagId])
}

model UserProfileTag {
  id     String     @id @default(cuid())
  userId String
  tagId  String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag    ProfileTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
}

model TaskApplication {
  id                  String            @id @default(cuid())
  message             String?
  status              ApplicationStatus @default(PENDING)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  taskId              String
  task                Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  applicantId         String
  applicant           User              @relation(fields: [applicantId], references: [id])
  skillMatchScore     Float?
  workloadScore       Float?
  completionRateScore Float?
  finalScore          Float?
  assignedBudget      Int?
  assignedXp          Int?
  completedAt         DateTime?
  onTime              Boolean?
  requirementId       String?
  requirement         TaskRequirement?  @relation(fields: [requirementId], references: [id], onDelete: SetNull)

  @@unique([taskId, applicantId])
  @@index([requirementId])
}

model TaskSubmission {
  id         String           @id @default(cuid())
  content    String
  status     SubmissionStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  taskId     String
  task       Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId String
  employee   User             @relation(fields: [employeeId], references: [id])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
}
